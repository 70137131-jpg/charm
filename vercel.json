{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.py"
    }
  ],
  "functions": {
    "index.py": {
      "maxDuration": 60,
      "includeFiles": "public/index.html",
      "excludeFiles": "{rag_pipeline/**,data/**,docs/**,examples/**,proj1/**}"
    }
  }
}
